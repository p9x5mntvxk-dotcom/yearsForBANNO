<!DOCTYPE html>
<html lang="ja">
<meta charset="UTF-8">
<style>
body {
    margin: 0;
    padding: 0;
    font-size: 16px;
    line-height: 1;
}
</style>

<span id="years"></span>

<script>
const startDate = new Date("2010-01-01"); // ←起算日をここで変更

function calcYears() {
    const today = new Date();
    let years = today.getFullYear() - startDate.getFullYear();
    const thisYearStart = new Date(today.getFullYear(), startDate.getMonth(), startDate.getDate());
    if (today < thisYearStart) years--;
    document.getElementById("years").textContent = years;
}

calcYears();
</script>
</html>
